HTTP_ADDR=:8081
CORS_ORIGIN=http://localhost:5173

# Local dev: a local Postgres, as below. Production: Neon's *direct*
# (non "-pooler") connection string - pgx's default extended query protocol
# prepares statements server-side per-connection, which breaks against
# Neon's PgBouncer transaction-mode pooler ("prepared statement already
# exists"). Direct is also fine for a small number of long-lived origin
# instances each holding a small bounded pool (see backend/internal/db/db.go
# Open()), unlike a per-request serverless caller.
DATABASE_URL=postgres://user:password@localhost:5432/amelu_saas

STALWART_BASE_URL=http://your-stalwart-host:8080
STALWART_ADMIN_USER=admin
STALWART_ADMIN_PASSWORD=

# Optional: Cloudflare Domain Connect "fix DNS automatically" flow. Until
# Cloudflare approves the template (see internal/domainconnect/template.json)
# and this is set, the feature just reports unsupported everywhere - it's
# safe to leave blank. Generate the key with:
#   go run ./cmd/domainconnect-keygen --pubkey-domain amelu.org
DOMAIN_CONNECT_PRIVATE_KEY=
DOMAIN_CONNECT_PUBKEY_DOMAIN=amelu.org
DOMAIN_CONNECT_REDIRECT_URI=

# Optional: Stripe billing. Until both are set, /api/billing/* reports the
# feature unavailable rather than failing startup. Use a test-mode secret key
# (sk_test_...) while developing. The webhook secret comes from the Stripe
# Dashboard's webhook endpoint config, or from `stripe listen --print-secret`
# when forwarding events to your local machine with the Stripe CLI.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional, Cloudflare-migration related (see docs/cloudflare/WORKFLOWS.md).
# EXPIRATION_SWEEP_MODE: "ticker" (default) keeps today's in-process
# goroutine. "external" disables it and requires
# INTERNAL_JOBS_SHARED_SECRET so an outside trigger (Cloudflare Worker Cron
# Trigger + Workflow, over the private Tunnel hostname only) can call
# POST /internal/jobs/expiration-sweep instead.
EXPIRATION_SWEEP_MODE=ticker
INTERNAL_JOBS_SHARED_SECRET=

# Optional. When set, every request must carry a valid X-Origin-Shared-Secret
# header signed with this value (see backend/internal/handlers/edge_auth.go
# and cloudflare/edge/src/sign.ts) - defense in depth proving the request
# passed through the edge Worker. Leave blank for local dev (frontend hits
# this backend directly, no Worker/Tunnel in the loop).
ORIGIN_SHARED_SECRET=

# Optional: "Login with Ordnary account" (see internal/ordnaryauth). Until
# ORDNARY_ISSUER/CLIENT_ID/REDIRECT_URI/COOKIE_SECRET are all set, that login
# option reports unavailable rather than failing startup. Register the
# client in ordnary-identity's Helm admin console (or a seed script, see
# ordnary-identity/CONTRIBUTING.md) with a redirect URI that exactly matches
# ORDNARY_REDIRECT_URI below - no wildcards. ORDNARY_CLIENT_SECRET is only
# needed for a confidential client; leave blank for public/PKCE-only.
ORDNARY_ISSUER=https://accounts.ordnary.com
ORDNARY_CLIENT_ID=amelu-client
ORDNARY_CLIENT_SECRET=
ORDNARY_REDIRECT_URI=http://localhost:8081/api/auth/ordnary/callback
ORDNARY_COOKIE_SECRET=

# Optional: cross-customer admin API for Helm (ordnary-identity/apps/helm,
# via services/helm-api) - see internal/handlers/admin.go and
# internal/auth/admin.go. Until set, the entire /internal/admin/* surface
# 503s (fails closed). Must match the same value configured in helm-api's
# AMELU_ADMIN_SHARED_SECRET / AMELU_API_URL.
AMELU_ADMIN_SHARED_SECRET=
