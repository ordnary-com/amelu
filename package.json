{
  "name": "amelu",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "dev": "concurrently -n frontend,backend -c blue,green \"pnpm dev:frontend\" \"pnpm dev:backend\"",
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:backend": "bash -c 'cd backend && set -a && source .env && set +a && go run ./cmd/api'",
    "build": "pnpm --filter frontend build"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
